{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xcue.schema/l3-patch-audit/1.0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "execution_mode",
    "status",
    "run_id",
    "task_id",
    "project_id",
    "chapter_source",
    "source_sha256",
    "patch_sha256",
    "正式正文保持不变"
  ],
  "properties": {
    "schema_version": {
      "const": "xcue.l3-patch-audit/1.0"
    },
    "execution_mode": {
      "const": "PATCH_EXECUTION"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING_APPROVAL",
        "PRECONDITION_CHECKED",
        "EXECUTED_IN_SANDBOX",
        "READY_FOR_ACCEPTANCE",
        "REJECTED",
        "APPLIED",
        "ROLLED_BACK",
        "EXECUTION_FAILED",
        "REVALIDATION_FAILED",
        "APPLY_FAILED",
        "ROLLBACK_FAILED",
        "ABORTED"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "chapter_source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "source_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "patch_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "正式正文保持不变": {
      "type": "boolean"
    },
    "final_status": {
      "type": "string"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
